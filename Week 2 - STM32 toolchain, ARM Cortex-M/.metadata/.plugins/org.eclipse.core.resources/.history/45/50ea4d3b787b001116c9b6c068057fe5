#include "stm32f4xx.h"

#define TIM2EN					(1U<<0)
#define CR1_CEN					(1U<<0)
#define OC_TOGGLE				((1U<<4) | (1U<<5))
#define CCER_CC1E				(1U<<0)
#define AFR5_TIM				(1U<<20)

#define TIM3EN					(1U<<1)
#define AFR6_TIM				(1U<<25)
#define CCER_CC1S 				(1U<<0)

#define GPIOAEN				   (1U<<0)
#define PIN5				   (1U<<5)
#define LED				   		PIN5


void tim2_1hz_init(void)
{
	/*Enable clock access to tim2*/
	RCC->APB1ENR |= TIM2EN;

	/*Set prescaler value*/
	TIM2->PSC = 1600 - 1;

	/*Set auto-reload value*/
	TIM2->ARR = 10000 - 1;

	/*Clear counter*/
	TIM2->CNT = 0;

	/*Enable timer*/
	TIM2->CR1 |= CR1_CEN;
}


void tim_pa5_output_compare(void)
{
	RCC->AHB1ENR |= GPIOAEN;

	// Set GPIOA to alternate function (not output!)
	GPIOA->MODER &=~(1U<<10);
	GPIOA->MODER |=(1U<<11);

	// At AFRL5, set to AF01
	GPIOA->AFR[0] |= AFR5_TIM;

	/*Enable clock access to tim2*/
	RCC->APB1ENR |=TIM2EN;

	/*Set prescaler value*/
	TIM2->PSC = 1600 - 1;

	/*Set auto-reload value*/
	TIM2->ARR = 10000 - 1;

	/*Set ch1 to output compare toggle mode*/
	TIM2->CCMR1 = OC_TOGGLE;

	// Enable tim2 chn1 in compare mode
	TIM2->CCER |= CCER_CC1E;

	// Clear counter
	TIM2->CNT = 0;

	// Enable timer
	TIM2->CR1 = CR1_CEN;
}


void tim3_pa6_input_capture(void)
{
	RCC->AHB1ENR |= GPIOAEN;

	// Set PA6 to alternate function
	GPIOA->MODER &=~ (1U<<12);
	GPIOA->MODER |=  (1U<<13);

	// Set Alternate function to AF2
	GPIOA->AFR[0] |= AFR6_TIM;

	/*Enable clock access to tim2*/
	RCC->APB1ENR |= TIM3EN;

	/*Set prescaler value*/
	TIM3->PSC = 16000 - 1;				// 16 000 000/16 000 = 1000 times per second -> ms

	// Set ch1 to input capture
	TIM3->CCMR1 = CCER_CC1S;

	// Set ch1 to capture at rising edge
	TIM3->CCER |= CCER_CC1E;

	// Enable timer
	TIM3->CR1 = CR1_CEN;

}
